# ── Application ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibe_grader
SESSION_SECRET=change-this-session-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# ── Docker Compose (PostgreSQL service) ──────────────────────────────────────
POSTGRES_DB=vibe_grader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password

# ── Web server ────────────────────────────────────────────────────────────────
PORT=3000

# ── Grading worker ────────────────────────────────────────────────────────────
# Interval (ms) between job-polling cycles
GRADING_WORKER_POLL_MS=2000
# Max submissions processed per polling cycle
GRADING_WORKER_BATCH_SIZE=5
